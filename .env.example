# Database Connection URL (Postgres/Neon compatible)
DATABASE_URL="postgresql://username:password@hostname:port/database_name?sslmode=require"

# ─── Firebase Client-Side Configuration ──────────────────────────────────────
# Obtain these from Firebase Console → Project Settings → Your Apps → Web App
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"

# ─── Firebase Server-Side Configuration (Keyless) ────────────────────────────
# No private key required. The Admin SDK verifies tokens against Google's
# public certificates using only the Project ID. No service account key needed.
FIREBASE_PROJECT_ID="your-project-id"
